// --------------------------------------------------
// HELPERS
// --------------------------------------------------
bool near(int x1, int y1, int x2, int y2, int d = 12) {
  return (abs(x1 - x2) <= d && abs(y1 - y2) <= d);
}

int findNearestVent(int row, int col, int px, int py) {
  int best = -1;
  int bestDist = 9999;

  for (int i = 0; i < NUM_VENTS; i++) {
    if (vents[i].row == row && vents[i].col == col) {
      int dx = px - vents[i].x;
      int dy = py - vents[i].y;
      int dist = abs(dx) + abs(dy);
      if (dist < bestDist) {
        bestDist = dist;
        best = i;
      }
    }
  }
  return best;
}

