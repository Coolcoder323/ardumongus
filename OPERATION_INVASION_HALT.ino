void initGame() {
  playerX = 40;
  playerY = 30;
  roomRow = 1;
  roomCol = 1;
  playerSuspicion = 0;

  inVent = false;
  meetingCalled = false;
  meetingTimer = 0;
  meetingResultTimer = 0;
  ejectedID = -1;

  sabotageDoors = false;
  doorTimer = 0;
  reactorMeltdown = false;
  impostorWin = false;
  crewmatesWin = false;
  playerEjected = false;

  meltdownTimer = MELTDOWN_START_FRAMES;
  meltdownCooldown = 0;
  ventCooldown = 0;

  // Set kill cooldown based on settings
  if (killCooldownOption == 0) killCooldownMaxFrames = 150;      // 5s
  else if (killCooldownOption == 1) killCooldownMaxFrames = 300; // 10s
  else if (killCooldownOption == 2) killCooldownMaxFrames = 450; // 15s

  killCooldown = killCooldownMaxFrames;

  for (int i = 0; i < NUM_CREWMATES; i++) {
    crewmates[i].x = random(10, ROOM_W - 10);
    crewmates[i].y = random(10, ROOM_H - 10);
    crewmates[i].alive = true;
    crewmates[i].roomRow = 1;
    crewmates[i].roomCol = 1;
    crewmates[i].targetRow = random(0, MAP_ROWS);
    crewmates[i].targetCol = random(0, MAP_COLS);
    crewmates[i].suspicion = 0;
    crewmates[i].tolerance = random(20, 80);
    crewmates[i].gotBodySuspicion = false;
  }
}

